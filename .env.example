# ===========================================
# PORTFOLIO API - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------
# Application
# -------------------------------------------
PORT=3000
NODE_ENV=development

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# -------------------------------------------
# Database (MySQL/MariaDB)
# -------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=yourpassword
DB_NAME=portfolio

# Database connection pool
DB_POOL_SIZE=10
DB_CONNECT_TIMEOUT=10000
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
DB_MAX_RETRIES=5
DB_RETRY_DELAY=5000

# Database SSL (optional)
DB_SSL_ENABLED=false
DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=/path/to/ca.pem
# DB_SSL_KEY=/path/to/key.pem
# DB_SSL_CERT=/path/to/cert.pem

# Database logging
DB_LOG_LEVELS=error,warn,schema

# Database cache (optional, requires Redis)
DB_CACHE_ENABLED=false
DB_CACHE_DURATION_MS=60000
DB_CACHE_ALWAYS_ENABLED=false

# -------------------------------------------
# Redis (optional - for caching)
# -------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
JWT_SECRET=yourjwtsecret-change-in-production
JWT_EXPIRES_IN=3600

# -------------------------------------------
# API Key Hashing Secret (REQUIRED for API keys)
# -------------------------------------------
# Generate with: openssl rand -hex 32
API_KEY_SECRET=your-api-key-secret-change-in-production

# -------------------------------------------
# Rate Limiting (Throttler)
# -------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=10
THROTTLE_PUBLIC_LIMIT=20
THROTTLE_STRICT_LIMIT=5

# -------------------------------------------
# Production Secrets (GitHub Actions)
# -------------------------------------------
# These must be set in GitHub Secrets for deployment:
# - DOCKER_USERNAME
# - DOCKER_PASSWORD
# - SSH_USERNAME
# - SSH_PRIVATE_KEY
# - DB_USERNAME
# - DB_PASSWORD
# - DB_NAME
# - MYSQL_ROOT_PASSWORD
# - JWT_SECRET
# - JWT_EXPIRES_IN
# - CORS_ORIGINS
# - API_KEY_SECRET
# - REDIS_PASSWORD
# - REDIS_TTL
# - THROTTLE_TTL
# - THROTTLE_LIMIT
# - THROTTLE_PUBLIC_LIMIT
# - THROTTLE_STRICT_LIMIT
